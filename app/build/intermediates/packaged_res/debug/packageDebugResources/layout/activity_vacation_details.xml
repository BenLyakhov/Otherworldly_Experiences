<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".UI.VacationDetails">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="411dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="120dp"
        android:background="#5198E0"

        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/vacation"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:text="Title: "
                    tools:layout_editor_absoluteX="154dp"
                    tools:layout_editor_absoluteY="366dp"></TextView>

                <EditText
                    android:id="@+id/titleText"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:hint="vacation 1"
                    tools:layout_editor_absoluteX="154dp"
                    tools:layout_editor_absoluteY="366dp"></EditText>

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/hotel"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:text="Hotel: "
                    tools:layout_editor_absoluteX="154dp"
                    tools:layout_editor_absoluteY="366dp"></TextView>

                <EditText
                    android:id="@+id/hotelName"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:hint="Hotel Name"
                    tools:layout_editor_absoluteX="154dp"
                    tools:layout_editor_absoluteY="366dp"></EditText>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/price"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:text="Price: "
                    tools:layout_editor_absoluteX="154dp"
                    tools:layout_editor_absoluteY="366dp"></TextView>

                <EditText
                    android:id="@+id/priceText"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:hint="price"
                    tools:layout_editor_absoluteX="154dp"
                    tools:layout_editor_absoluteY="366dp"></EditText>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:padding="10dp"
                    android:text="start date: "></TextView>

                <TextView
                    android:id="@+id/startvacadate"
                    android:layout_width="200dp"
                    android:layout_height="match_parent"
                    android:background="#1477DC"
                    android:textSize="20dp"
                    android:hint="select start date"
                    android:inputType="none" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="87dp"
                    android:layout_height="50dp"
                    android:padding="10dp"
                    android:text="end date: "></TextView>

                <TextView
                    android:id="@+id/endvacadate"
                    android:layout_width="200dp"
                    android:layout_height="match_parent"
                    android:inputType="none"
                    android:background="#1477DC"
                    android:textSize="20dp"
                    android:hint="select end date"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/floatingActionButton2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:layout_margin="40dp"
        android:src="@drawable/baseline_add_24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/excursionRecyclerView"
        android:layout_width="409dp"
        android:layout_height="470dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/scrollView" />


</androidx.constraintlayout.widget.ConstraintLayout>